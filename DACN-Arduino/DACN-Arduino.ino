// ================= BIẾN TOÀN CỤC =================
int x = LEDMATRIX_WIDTH;
int brightness = 2;

char text[75] = " San Sang ";
int len = strlen(text);

const int ANIM_DELAY = 75;
int animationSpeed = ANIM_DELAY;
unsigned long myTime = 0;

IPAddress ip;

enum DisplayState { STOPPED, RUNNING };
DisplayState currentState = RUNNING;

int numLoops = 1;
int currentLoop = 0;
bool displayOn = true;

bool enableBlink = false;
bool showText = true;
unsigned long lastBlinkTime = 0;
const int BLINK_INTERVAL = 500;

// Thêm biến effect
int textEffect = 0;      // 0 = chạy ngang cũ, 1 = hiện từng chữ dạng 4 ô
int typeIndex = 0;
unsigned long effectTime = 0;
const int TYPE_DELAY = 400;

// ================= HÀM HỖ TRỢ =================
String urlDecode(String input) {
  String decoded = "";
  char temp[] = "0x00";

  for (unsigned int i = 0; i < input.length(); i++) {
    char c = input.charAt(i);

    if (c == '+') {
      decoded += ' ';
    } else if (c == '%' && i + 2 < input.length()) {
      temp[2] = input.charAt(i + 1);
      temp[3] = input.charAt(i + 2);
      decoded += (char)strtol(temp, NULL, 16);
      i += 2;
    } else {
      decoded += c;
    }
  }

  return decoded;
}

String getParam(String params, String key) {
  String searchKey = key + "=";
  int start = params.indexOf(searchKey);
  if (start < 0) return "";

  start += searchKey.length();

  int end = params.indexOf('&', start);
  if (end < 0) end = params.indexOf(' ', start);
  if (end < 0) end = params.length();

  return params.substring(start, end);
}

void safeCopyText(const String& src) {
  String clean = src;
  clean.replace("\r", "");
  clean.replace("\n", "");

  strncpy(text, clean.c_str(), sizeof(text) - 1);
  text[sizeof(text) - 1] = '\0';
  len = strlen(text);
}

void drawSprite(byte* sprite, int x, int y, int width, int height) {
  for (int iy = 0; iy < height; iy++) {
    byte mask = B10000000;

    for (int ix = 0; ix < width; ix++) {
      bool pixel = sprite[iy] & mask;

      int px = x + (width - 1 - ix);
      int py = y + iy;

      if (px >= 0 && px < LEDMATRIX_WIDTH && py >= 0 && py < LEDMATRIX_HEIGHT) {
        lmd.setPixel(px, py, pixel);
      }

      mask >>= 1;
    }
  }
}

void drawString(char* textPtr, int lenText, int xPos, int yPos) {
  for (int idx = 0; idx < lenText; idx++) {
    char ch = textPtr[idx];

    if (ch < 32 || ch > 126) continue;

    int c = ch - 32;

    if (c < 0 || c >= 95) continue;

    int charX = xPos + idx * 8;

    if (charX >= LEDMATRIX_WIDTH) continue;
    if (charX + 7 < 0) continue;

    drawSprite(font[c], charX, yPos, 8, 8);
  }
}

